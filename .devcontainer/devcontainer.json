{
  // arm:9.70.1-st
  // IAR Build Tools for Arm w/ ST device support
    // Update the image for use with other variants
  // More information: https://github.com/iarsystems/containers/wiki/Arm-image-variants
  "image": "ghcr.io/iarsystems/arm:9.70.1-st",
  
  // Set the Container's environment variables
  "containerEnv": {
    "HOME": "/home/ubuntu",
    "IAR_LMS_BEARER_TOKEN": "${localEnv:IAR_LMS_BEARER_TOKEN}"
  },
  
  // Customizations installs the IAR Extensions for VS Code
  // More information: https://iar.com/vscode
  "customizations": {
    "vscode": {
      "extensions": [
        //"iarsystems.iar-extension-pack",
        "iarsystems.iar-debug",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode-remote.vscode-remote-extensionpack",
        "github.vscode-github-actions"
        
      ]
    }
  },
  
  // The container's features installed at build-time
  "features": {
    "./jlink": {},
    "./lmsc": {},
    "./usb": {}
  },

  // Comment out "remoteUser" to connect as `root` instead
  // More information: https://containers.dev/implementors/json_reference/#remoteUser
  "remoteUser": "ubuntu",

  // Uncomment for exposing the host's USB bus to the dev container
  // "runArgs": [
  //   "--device=/dev/bus/usb"
  // ],
  
  // Initialize git submodules
  "postAttachCommand": "git submodule update --init --recursive",
  
  // Port forwarding
  "forwardPorts": []
}
